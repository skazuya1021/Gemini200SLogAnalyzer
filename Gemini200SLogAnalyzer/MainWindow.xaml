<Window x:Class="Gemini200SLogAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:Gemini200SLogAnalyzer.Models"
        xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        Title="Gemini200S Log Analyzer v1.3.5"
        Height="860"
        Width="1280"
        MinHeight="700"
        MinWidth="1000"
        Background="{StaticResource SurfaceBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Gemini200S Log Analyzer"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="#0F172A"/>
            <TextBlock x:Name="SubtitleTextBlock"
                       Text="Gemini200S ログファイルの合体・分析・グラフ表示"
                       Margin="0,4,0,0"
                       Foreground="#475569"/>
        </StackPanel>

        <TabControl Grid.Row="1" x:Name="MainTabControl" SelectionChanged="MainTabControl_SelectionChanged">
            <!-- ファイル読込み -->
            <TabItem Header="ファイル読込み">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="データ種別" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="DataSourceComboBox" Width="260" HorizontalAlignment="Left"
                                  Margin="0,0,0,8" SelectionChanged="DataSourceComboBox_SelectionChanged">
                            <ComboBoxItem Content="Wafer Log (.log)" Tag="WaferLog" IsSelected="True"/>
                            <ComboBoxItem Content="ManualLog (.csv)" Tag="ManualLog"/>
                        </ComboBox>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="SelectFilesButton" Content="ファイルを選択..." Width="150" Height="32" Margin="0,0,8,0"
                                    Click="SelectFiles_Click"/>
                            <Button x:Name="SelectFolderButton" Content="フォルダを選択..." Width="150" Height="32"
                                    Click="SelectFolder_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Text="選択されたファイル" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ListBox Grid.Row="2" x:Name="SelectedFilesListBox" Height="160" Margin="0,0,0,12"
                             BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="1"/>

                    <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource BorderBrushColor}"
                            BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="合体データ概要" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock x:Name="MergeSummaryTextBlock" Text="データ未読込" Foreground="#64748B"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="4" Orientation="Horizontal">
                        <Button x:Name="MergeButton" Content="ログファイルを合体" Width="180" Height="34" Margin="0,0,8,0"
                                Click="MergeLogs_Click"/>
                        <Button Content="CSVとして出力..." Width="160" Height="34"
                                Click="ExportCsv_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- データ表示 -->
            <TabItem Header="データ表示">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource BorderBrushColor}"
                            BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,8,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="項目選択 (5列目以降)" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <ListBox Grid.Row="1" x:Name="ColumnListBox" SelectionMode="Extended"
                                     BorderThickness="0" PreviewMouseLeftButtonDown="ColumnListBox_PreviewMouseLeftButtonDown">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:ColumnSelectionItem}">
                                        <CheckBox Content="{Binding Name}"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  Margin="2"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <TextBlock Grid.Row="2" Text="フィルター" FontWeight="SemiBold" Margin="0,10,0,6"/>
                            <StackPanel Grid.Row="3" Margin="0,0,0,8">
                                <TextBlock Text="日付 (From)"/>
                                <DatePicker x:Name="DateFromPicker" Margin="0,2,0,6"
                                            SelectedDateChanged="DateRangePicker_SelectedDateChanged"/>
                                <TextBlock Text="日付 (To)"/>
                                <DatePicker x:Name="DateToPicker" Margin="0,2,0,6"
                                            SelectedDateChanged="DateRangePicker_SelectedDateChanged"/>
                                <TextBlock Text="Lot ID"/>
                                <ComboBox x:Name="LotIdFilterComboBox" Margin="0,2,0,6"/>
                                <TextBlock Text="Recipe ID"/>
                                <ComboBox x:Name="RecipeIdFilterComboBox" Margin="0,2,0,6"/>
                            </StackPanel>

                            <TextBlock Grid.Row="4" Text="統計値" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <StackPanel Grid.Row="5" Margin="0,0,0,10">
                                <CheckBox x:Name="MedianCheckBox" Content="Median" IsChecked="True" IsEnabled="False"/>
                                <CheckBox x:Name="AverageCheckBox" Content="Average"/>
                                <CheckBox x:Name="MaxCheckBox" Content="Max"/>
                                <CheckBox x:Name="MinCheckBox" Content="Min"/>
                            </StackPanel>

                            <Button Grid.Row="6" Content="データ表示" Height="32" Click="ShowData_Click"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <DataGrid Grid.Row="0" x:Name="AnalysisDataGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  AlternatingRowBackground="#F8FAFC"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True"
                                  RowHeight="24"
                                  Loaded="AnalysisDataGrid_Loaded"/>
                        <TextBlock Grid.Row="1" x:Name="AnalysisGridStatusTextBlock"
                                   Margin="0,6,0,0" Foreground="#64748B" FontSize="11"/>
                        <Button Grid.Row="2" Content="Excel形式で保存..." HorizontalAlignment="Right"
                                Width="160" Height="32" Margin="0,8,0,0"
                                Click="ExportExcel_Click"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- グラフ -->
            <TabItem Header="グラフ">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource BorderBrushColor}"
                            BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,8,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="グラフ種類" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <WrapPanel Margin="0,0,0,12">
                                    <RadioButton x:Name="ChartLineRadioButton" Content="折れ線"
                                                 GroupName="ChartStyle" IsChecked="True" Margin="0,0,12,4"
                                                 Checked="ChartStyleRadioButton_Checked"/>
                                    <RadioButton x:Name="ChartDotRadioButton" Content="ドット"
                                                 GroupName="ChartStyle" Margin="0,0,12,4"
                                                 Checked="ChartStyleRadioButton_Checked"/>
                                    <RadioButton x:Name="ChartAreaRadioButton" Content="面"
                                                 GroupName="ChartStyle" Margin="0,0,12,4"
                                                 Checked="ChartStyleRadioButton_Checked"/>
                                    <RadioButton x:Name="ChartBarRadioButton" Content="棒"
                                                 GroupName="ChartStyle" Margin="0,0,12,4"
                                                 Checked="ChartStyleRadioButton_Checked"/>
                                    <RadioButton x:Name="ChartScatterRadioButton" Content="散布図"
                                                 GroupName="ChartStyle" Margin="0,0,12,4"
                                                 Checked="ChartStyleRadioButton_Checked"/>
                                </WrapPanel>

                                <StackPanel x:Name="ScatterSettingsPanel" Visibility="Collapsed" Margin="0,0,0,12">
                                    <TextBlock Text="散布図の軸設定" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBlock Text="X軸"/>
                                    <ComboBox x:Name="ScatterXAxisComboBox" Margin="0,2,0,6"
                                              SelectionChanged="ScatterAxisComboBox_SelectionChanged"/>
                                    <TextBlock Text="Y軸"/>
                                    <ComboBox x:Name="ScatterYAxisComboBox" Margin="0,2,0,6"
                                              SelectionChanged="ScatterAxisComboBox_SelectionChanged"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Button Content="組み合わせ追加" Padding="8,2" Margin="0,0,6,0"
                                                Click="AddScatterPair_Click"/>
                                        <Button Content="Y一括追加" Padding="8,2"
                                                Click="AddScatterPairsFromSelectedY_Click"/>
                                    </StackPanel>
                                    <TextBlock Text="散布図の組み合わせ" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ListBox x:Name="ScatterPairListBox" MaxHeight="120" BorderThickness="1"
                                             BorderBrush="{StaticResource BorderBrushColor}" Margin="0,0,0,6">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type models:ScatterPairItem}">
                                                <CheckBox Content="{Binding DisplayName}"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          Checked="ScatterPairCheckBox_Changed"
                                                          Unchecked="ScatterPairCheckBox_Changed"
                                                          Margin="2"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <Button Content="組み合わせをクリア" Padding="8,2"
                                            Click="ClearScatterPairs_Click"/>
                                </StackPanel>

                                <TextBlock Text="Lot ID" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Button Content="一括選択" Padding="8,2" Margin="0,0,6,0"
                                            Click="ChartLotSelectAll_Click"/>
                                    <Button Content="一括解除" Padding="8,2"
                                            Click="ChartLotDeselectAll_Click"/>
                                </StackPanel>
                                <ListBox x:Name="ChartLotListBox" MaxHeight="100" BorderThickness="1"
                                         BorderBrush="{StaticResource BorderBrushColor}" Margin="0,0,0,10">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:ColumnSelectionItem}">
                                            <CheckBox Content="{Binding Name}"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      Checked="ChartFilterCheckBox_Changed"
                                                      Unchecked="ChartFilterCheckBox_Changed"
                                                      Margin="2"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <TextBlock Text="Recipe ID" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Button Content="一括選択" Padding="8,2" Margin="0,0,6,0"
                                            Click="ChartRecipeSelectAll_Click"/>
                                    <Button Content="一括解除" Padding="8,2"
                                            Click="ChartRecipeDeselectAll_Click"/>
                                </StackPanel>
                                <ListBox x:Name="ChartRecipeListBox" MaxHeight="100" BorderThickness="1"
                                         BorderBrush="{StaticResource BorderBrushColor}" Margin="0,0,0,10">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:ColumnSelectionItem}">
                                            <CheckBox Content="{Binding Name}"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      Checked="ChartFilterCheckBox_Changed"
                                                      Unchecked="ChartFilterCheckBox_Changed"
                                                      Margin="2"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <TextBlock Text="Cassette" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <ListBox x:Name="ChartCassetteListBox" MaxHeight="100" BorderThickness="1"
                                         BorderBrush="{StaticResource BorderBrushColor}" Margin="0,0,0,10">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:ColumnSelectionItem}">
                                            <CheckBox Content="{Binding Name}"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      Checked="ChartFilterCheckBox_Changed"
                                                      Unchecked="ChartFilterCheckBox_Changed"
                                                      Margin="2"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <StackPanel x:Name="TimeSeriesColumnPanel">
                                <TextBlock Text="グラフ表示項目" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="Y軸: L=左 / R=右（2項目以上で有効）" FontSize="10"
                                           Foreground="#64748B" Margin="0,0,0,4"/>
                                <ListBox x:Name="ChartColumnListBox" MaxHeight="160" BorderThickness="1"
                                         BorderBrush="{StaticResource BorderBrushColor}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:ColumnSelectionItem}">
                                            <Grid Margin="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0"
                                                          Content="{Binding Name}"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          Checked="ChartColumnCheckBox_Changed"
                                                          Unchecked="ChartColumnCheckBox_Changed"
                                                          VerticalAlignment="Center"/>
                                                <ComboBox Grid.Column="1" Width="52" Height="22" Margin="4,0,0,0"
                                                          SelectedIndex="{Binding YAxisSideIndex, Mode=TwoWay}"
                                                          SelectionChanged="ChartYAxisSide_Changed"
                                                          ToolTip="Y軸（左/右）">
                                                    <ComboBoxItem Content="L"/>
                                                    <ComboBoxItem Content="R"/>
                                                </ComboBox>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                </StackPanel>
                                <Button Content="グラフ更新" Height="32" Margin="0,10,0,6"
                                        Click="UpdateChart_Click"/>
                                <Button Content="表示リセット" Height="32"
                                        Click="ResetChartDisplay_Click"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderBrushColor}"
                                BorderThickness="1" CornerRadius="6" Padding="4">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <scottplot:WpfPlot x:Name="ChartPlot"
                                                   Grid.Row="0"
                                                   MouseMove="ChartPlot_MouseMove"
                                                   MouseLeave="ChartPlot_MouseLeave"
                                                   PreviewMouseLeftButtonDown="ChartPlot_PreviewMouseLeftButtonDown"
                                                   PreviewMouseMove="ChartPlot_PreviewMouseMove"
                                                   PreviewMouseLeftButtonUp="ChartPlot_PreviewMouseLeftButtonUp"
                                                   PreviewMouseWheel="ChartPlot_InteractionChanged"
                                                   MouseUp="ChartPlot_InteractionChanged"/>
                                <TextBlock x:Name="ChartPlotStatusTextBlock" Grid.Row="1"
                                           FontSize="10" Foreground="#64748B" Margin="4,2,0,0"/>
                            </Grid>
                        </Border>
                        <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="{StaticResource BorderBrushColor}"
                                BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,8,0,0">
                            <StackPanel>
                                <CheckBox x:Name="ChartCrosshairCheckBox"
                                          Content="カーソル位置を表示（クロスヘア）"
                                          IsChecked="True"
                                          Checked="ChartCrosshairCheckBox_Changed"
                                          Unchecked="ChartCrosshairCheckBox_Changed"/>
                                <CheckBox x:Name="DiffMeasureCheckBox"
                                          Content="2点間差分測定"
                                          Margin="0,4,0,0"
                                          Checked="DiffMeasureCheckBox_Changed"
                                          Unchecked="DiffMeasureCheckBox_Changed"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <RadioButton x:Name="DiffTargetCursorMoveRadioButton" Content="カーソル移動"
                                                 GroupName="DiffTarget" IsChecked="True" Margin="0,0,12,0"/>
                                    <RadioButton x:Name="DiffTargetPoint1RadioButton" Content="点1を指定"
                                                 GroupName="DiffTarget" Margin="0,0,12,0"/>
                                    <RadioButton x:Name="DiffTargetPoint2RadioButton" Content="点2を指定"
                                                 GroupName="DiffTarget"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="点1から" VerticalAlignment="Center"/>
                                    <TextBox x:Name="DiffOffsetValueTextBox" Width="48" Height="24"
                                             Text="10" Margin="6,0,4,0" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="DiffOffsetUnitComboBox" Width="56" Height="24"
                                              SelectedIndex="1" VerticalAlignment="Center">
                                        <ComboBoxItem Content="秒"/>
                                        <ComboBoxItem Content="分"/>
                                        <ComboBoxItem Content="時間"/>
                                    </ComboBox>
                                    <TextBlock Text="後を点2に" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                    <Button Content="点2自動設定" Padding="8,2" Margin="8,0,0,0"
                                            Click="ApplyAutoDiffPoint2_Click"/>
                                </StackPanel>
                                <CheckBox x:Name="DiffAutoPoint2CheckBox" Margin="0,4,0,0"
                                          Content="点1指定後に自動で点2を設定"/>
                                <TextBlock x:Name="ChartCursorInfoTextBlock"
                                           Text="カーソルをグラフ上に移動すると、最寄りのデータ点の値を表示します。"
                                           TextWrapping="Wrap" FontSize="11"
                                           Foreground="#334155" Margin="0,6,0,0"/>
                                <TextBlock x:Name="ChartDiffInfoTextBlock"
                                           TextWrapping="Wrap" FontSize="11"
                                           Foreground="#B45309" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <StackPanel Grid.Row="2" Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,6">
                                <CheckBox x:Name="PngIncludeCursorCheckBox"
                                          Content="PNGにカーソル位置データを含める"
                                          IsChecked="True" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                <CheckBox x:Name="PngIncludeDiffCheckBox"
                                          Content="PNGに2点間差分データを含める"
                                          IsChecked="True" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="表示をリセット" Width="120" Height="32" Margin="0,0,8,0"
                                        Click="ResetChartPlotView_Click"/>
                                <Button Content="差分をクリア" Width="120" Height="32" Margin="0,0,8,0"
                                        Click="ClearChartDiff_Click"/>
                                <Button Content="CSVとして保存..." Width="160" Height="32" Margin="0,0,8,0"
                                        Click="SaveChartCsv_Click"/>
                                <Button Content="PNGとして保存..." Width="160" Height="32"
                                        Click="SaveChartPng_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- 変動確認 -->
            <TabItem Header="変動確認">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource BorderBrushColor}"
                            BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,8,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="測定ポイント" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock x:Name="VariationPointStatusTextBlock"
                                           Text="グラフタブで点1・点2を指定してください。"
                                           TextWrapping="Wrap" Foreground="#64748B" Margin="0,0,0,10"/>

                                <TextBlock Text="分析項目" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <ComboBox x:Name="VariationSeriesComboBox" Margin="0,0,0,10"/>

                                <TextBlock Text="分析方式" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <StackPanel Margin="0,0,0,8">
                                    <RadioButton x:Name="VariationTimeModeRadioButton" Content="時間間隔"
                                                 GroupName="VariationMode" IsChecked="True" Margin="0,0,0,4"/>
                                    <RadioButton x:Name="VariationValueModeRadioButton" Content="値間隔（Y軸）"
                                                 GroupName="VariationMode"/>
                                </StackPanel>

                                <CheckBox x:Name="VariationAutoIntervalCheckBox" Content="間隔を自動設定"
                                          IsChecked="True" Margin="0,0,0,6"/>

                                <StackPanel x:Name="VariationTimeIntervalPanel" Margin="0,0,0,8">
                                    <TextBlock Text="時間間隔"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBox x:Name="VariationTimeIntervalTextBox" Width="48" Height="24"
                                                 Text="10" Margin="0,0,4,0"/>
                                        <ComboBox x:Name="VariationTimeUnitComboBox" Width="56" Height="24"
                                                  SelectedIndex="1">
                                            <ComboBoxItem Content="秒"/>
                                            <ComboBoxItem Content="分"/>
                                            <ComboBoxItem Content="時間"/>
                                        </ComboBox>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel x:Name="VariationValueIntervalPanel" Margin="0,0,0,8"
                                            Visibility="Collapsed">
                                    <TextBlock Text="値間隔（Y軸）"/>
                                    <TextBox x:Name="VariationValueStepTextBox" Height="24" Margin="0,2,0,0"
                                             Text="5"/>
                                </StackPanel>

                                <Button Content="変動分析を実行" Height="32" Margin="0,6,0,6"
                                        Click="RunVariationAnalysis_Click"/>
                                <Button Content="グラフタブの点を使用" Height="28"
                                        Click="RefreshVariationPointStatus_Click"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" MinHeight="180"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*" MinHeight="140"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderBrushColor}"
                                BorderThickness="1" CornerRadius="6" Padding="4">
    <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <scottplot:WpfPlot x:Name="VariationPlot"
                                                   Grid.Row="0"
                                                   PreviewMouseWheel="VariationPlot_InteractionChanged"
                                                   MouseUp="VariationPlot_InteractionChanged"/>
                                <TextBlock x:Name="VariationPlotStatusTextBlock" Grid.Row="1"
                                           FontSize="10" Foreground="#64748B" Margin="4,2,0,0"/>
                            </Grid>
                        </Border>
                        <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                                      Background="Transparent" Margin="0,4"/>
                        <DataGrid Grid.Row="2" x:Name="VariationAnalysisDataGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  AlternatingRowBackground="#F8FAFC"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"/>
                        <Button Grid.Row="3" Content="表示をリセット" HorizontalAlignment="Left"
                                Width="120" Height="28" Margin="0,8,0,0"
                                Click="ResetVariationPlotView_Click"/>
                        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right"
                                    Margin="0,8,0,0">
                            <Button Content="PNGとして保存..." Width="160" Height="32" Margin="0,0,8,0"
                                    Click="SaveVariationPng_Click"/>
                            <Button Content="CSVとして保存..." Width="160" Height="32"
                                    Click="ExportVariationCsv_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- プログレスバー -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderBrushColor}"
                BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,12,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" x:Name="ProgressStatusTextBlock" Text="待機中" Foreground="#475569"/>
                <ProgressBar Grid.Row="1" x:Name="ProgressBar" Height="18" Margin="0,6,0,0"
                             Minimum="0" Maximum="100" Value="0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
